# .env.example
# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามจริง — ห้าม commit ไฟล์ .env จริงขึ้น Git

# ---------- PostgreSQL (อ่านโดย backend/db.js ผ่าน DB_* ตรงกับที่ docker-compose ส่งเข้าไป) ----------
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=laptop_market

# ---------- Backend ----------
NODE_ENV=development
PORT=3000

# ---------- Docker Hub (ใช้กับ docker-compose.prod.yml และ CD workflow) ----------
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ---------- Host port mapping (ใช้กับ docker-compose dev/prod) ----------
BACKEND_PORT=3000
FRONTEND_PORT=8080
