# ---- Backend ----
NODE_ENV=development
PORT=3000

# ---- PostgreSQL (ใช้ร่วมกันทั้ง backend/db.js และ container postgres) ----
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=laptop_market

# ---- พอร์ตที่ map ออกมาที่เครื่อง host เมื่อรันผ่าน docker-compose ----
BACKEND_PORT=3000
FRONTEND_PORT=8080

# ---- ใช้เฉพาะ docker-compose.prod.yml (ดึง image จาก Docker Hub) ----
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest
