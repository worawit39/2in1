# .env.example
# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามจริง
# ห้าม push ไฟล์ .env จริง (มีอยู่ใน .gitignore แล้ว)

# ---------- PostgreSQL ----------
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=laptop_market

# ---------- Backend ----------
PORT=3000

# ---------- Docker Hub (ใช้กับ docker-compose.prod.yml) ----------
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# ---------- Frontend (ใช้กับ docker-compose dev, map host port) ----------
FRONTEND_PORT=8080
BACKEND_PORT=3000
