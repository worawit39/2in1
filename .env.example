# ---- Backend ----
NODE_ENV=development
PORT=3000

# PostgreSQL connection (used by backend/db.js)
DATABASE_URL=postgres://marketplace_user:marketplace_pass@postgres:5432/marketplace_db

# Individual PG vars (fallback if DATABASE_URL is not set)
PGHOST=postgres
PGPORT=5432
PGUSER=marketplace_user
PGPASSWORD=marketplace_pass
PGDATABASE=marketplace_db

# ---- Postgres container ----
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=marketplace_pass
POSTGRES_DB=marketplace_db

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:3000
